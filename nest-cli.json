{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/hospital/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/hospital/tsconfig.app.json"
  },
  "monorepo": true,
  "defaultLibraryPrefix": "@app",
  "root": "apps/hospital",
  "projects": {
    "hospital": {
      "type": "application",
      "root": "apps/hospital",
      "entryFile": "main",
      "sourceRoot": "apps/hospital/src",
      "compilerOptions": {
        "tsConfigPath": "apps/hospital/tsconfig.app.json"
      }
    },
    "appointment": {
      "type": "application",
      "root": "apps/appointment",
      "entryFile": "main",
      "sourceRoot": "apps/appointment/src",
      "compilerOptions": {
        "tsConfigPath": "apps/appointment/tsconfig.app.json"
      }
    },
    "billing": {
      "type": "application",
      "root": "apps/billing",
      "entryFile": "main",
      "sourceRoot": "apps/billing/src",
      "compilerOptions": {
        "tsConfigPath": "apps/billing/tsconfig.app.json"
      }
    },
    "lab": {
      "type": "application",
      "root": "apps/lab",
      "entryFile": "main",
      "sourceRoot": "apps/lab/src",
      "compilerOptions": {
        "tsConfigPath": "apps/lab/tsconfig.app.json"
      }
    },
    "notification": {
      "type": "application",
      "root": "apps/notification",
      "entryFile": "main",
      "sourceRoot": "apps/notification/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notification/tsconfig.app.json"
      }
    },
    "patient": {
      "type": "application",
      "root": "apps/patient",
      "entryFile": "main",
      "sourceRoot": "apps/patient/src",
      "compilerOptions": {
        "tsConfigPath": "apps/patient/tsconfig.app.json"
      }
    },
    "pharmacy": {
      "type": "application",
      "root": "apps/pharmacy",
      "entryFile": "main",
      "sourceRoot": "apps/pharmacy/src",
      "compilerOptions": {
        "tsConfigPath": "apps/pharmacy/tsconfig.app.json"
      }
    },
    "prescription": {
      "type": "application",
      "root": "apps/prescription",
      "entryFile": "main",
      "sourceRoot": "apps/prescription/src",
      "compilerOptions": {
        "tsConfigPath": "apps/prescription/tsconfig.app.json"
      }
    },
    "cache": {
      "type": "library",
      "root": "shared/cache",
      "entryFile": "index",
      "sourceRoot": "shared/cache/src",
      "compilerOptions": {
        "tsConfigPath": "shared/cache/tsconfig.lib.json"
      }
    },
    "common": {
      "type": "library",
      "root": "shared/common",
      "entryFile": "index",
      "sourceRoot": "shared/common/src",
      "compilerOptions": {
        "tsConfigPath": "shared/common/tsconfig.lib.json"
      }
    },
    "database": {
      "type": "library",
      "root": "shared/database",
      "entryFile": "index",
      "sourceRoot": "shared/database/src",
      "compilerOptions": {
        "tsConfigPath": "shared/database/tsconfig.lib.json"
      }
    },
    "queue": {
      "type": "library",
      "root": "shared/queue",
      "entryFile": "index",
      "sourceRoot": "shared/queue/src",
      "compilerOptions": {
        "tsConfigPath": "shared/queue/tsconfig.lib.json"
      }
    },
    "supabase-auth": {
      "type": "library",
      "root": "shared/supabase-auth",
      "entryFile": "index",
      "sourceRoot": "shared/supabase-auth/src",
      "compilerOptions": {
        "tsConfigPath": "shared/supabase-auth/tsconfig.lib.json"
      }
    }
  }
}
