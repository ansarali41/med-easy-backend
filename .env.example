NODE_ENV=development

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxx
SUPABASE_SERVICE_KEY=eyJxxxxxx

# Database (local dev)
POSTGRESQL_DATABASE_URL=

# Redis (local dev — use Upstash in prod)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Email (Resend free — 100/day)
RESEND_API_KEY=re_xxxxx

# File Storage
SUPABASE_STORAGE_BUCKET=hms-files

# Hospital Registration — secret key required to onboard a new hospital
ONBOARD_SECRET_KEY=your-secret-key-here

# Service Ports
HOSPITAL_SERVICE_PORT=3001
APPOINTMENT_SERVICE_PORT=3002
PATIENT_SERVICE_PORT=3003
PRESCRIPTION_SERVICE_PORT=3004
PHARMACY_SERVICE_PORT=3005
BILLING_SERVICE_PORT=3006
NOTIFICATION_SERVICE_PORT=3007
LAB_SERVICE_PORT=3008
